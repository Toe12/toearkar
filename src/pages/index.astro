---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  contact,
  about,
  education,
  experiences,
  personalProjects,
  skills
} from "../data/cvData.js";

const cvPdfLink = "/cv.pdf";
---

<BaseLayout>
  <!-- Hero / Intro Section (Minimal) -->
  <section class="mb-5 text-center">
    <h1 class="h3 mb-1">Toe Arkar</h1>
    <p class="text-muted mb-3">Founding Software Engineer @ We Care Insurance</p>

    <!-- Download CV Button -->
    <a
      class="btn btn-outline-primary btn-sm"
      href={cvPdfLink}
      target="_blank"
      rel="noopener noreferrer"
    >
      <i class="bi bi-file-earmark-arrow-down me-1"></i> Download CV
    </a>
  </section>

  <!-- About Section -->
  <section class="mb-5">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-secondary text-white">
        <h2 class="h4 m-0">
          <i class="bi bi-info-circle-fill me-2"></i>About
        </h2>
      </div>
      <div class="card-body">
        <p>
          {about.aboutMe}
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="mb-5">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-secondary text-white">
        <h2 class="h4 m-0">
          <i class="bi bi-person-lines-fill me-2"></i>Contact
        </h2>
      </div>
      <div class="card-body">
        <div class="mb-3">
          <i class="bi bi-envelope me-2"></i>
          <strong>Email:</strong>{" "}
          <a href={`mailto:${contact.email}`} class="text-decoration-none">
            {contact.email}
          </a>
        </div>
        <div class="mb-3">
          <i class="bi bi-linkedin me-2"></i>
          <strong>LinkedIn:</strong>{" "}
          <a
            href={contact.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="text-decoration-none"
          >
            {contact.linkedin}
          </a>
        </div>
        <div class="mb-3">
          <i class="bi bi-github me-2"></i>
          <strong>GitHub:</strong>{" "}
          <a
            href={contact.github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-decoration-none"
          >
            {contact.github}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Education Section -->
  <section class="mb-5">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-secondary text-white">
        <h2 class="h4 m-0">
          <i class="bi bi-mortarboard-fill me-2"></i>Education
        </h2>
      </div>
      <div class="card-body">
        {education.map((ed) => (
          <div class="mb-4">
            <h5 class="mb-1">{ed.degree}</h5>
            <p class="text-muted mb-1">
              {ed.institution}, {ed.location} | {ed.dateRange}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Professional Experience Section -->
  <section class="mb-5">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-secondary text-white">
        <h2 class="h4 m-0">
          <i class="bi bi-briefcase-fill me-2"></i>Professional Experience
        </h2>
      </div>
      <div class="card-body">
        {experiences.map((exp) => (
          <div class="mb-4">
            <h5 class="mb-1">{exp.title}</h5>
            <p class="text-muted mb-1">
              {exp.company} | {exp.dateRange}
            </p>
            <ul class="small mb-0">
              {exp.responsibilities.map((resp) => (
                <li>{resp}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Personal Projects Section -->
  <section class="mb-5">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-secondary text-white">
        <h2 class="h4 m-0">
          <i class="bi bi-lightbulb-fill me-2"></i>Personal Projects
        </h2>
      </div>
      <div class="card-body">
        {personalProjects.map((project) => (
          <div class="mb-4">
            <h5 class="mb-1">{project.name}</h5>
            <p class="small">{project.description}</p>
            {project.posterLink && (
              <p class="small mb-0">
                Poster Link:{" "}
                <a
                  href={project.posterLink}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {project.posterLink}
                </a>
              </p>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section class="mb-5">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-secondary text-white">
        <h2 class="h4 m-0">
          <i class="bi bi-tools me-2"></i>Skills
        </h2>
      </div>
      <div class="card-body small">
        <div class="row mb-2">
          <div class="col-md-6 mb-2">
            <strong>Languages:</strong> {skills.languages.join(", ")}
          </div>
          <div class="col-md-6 mb-2">
            <strong>Databases:</strong> {skills.databases.join(", ")}
          </div>
          <div class="col-md-6 mb-2">
            <strong>Version Control &amp; Issue Tracking:</strong>{" "}
            {skills.versionControl.join(", ")}
          </div>
          <div class="col-md-6 mb-2">
            <strong>Frameworks &amp; Libraries:</strong>{" "}
            {skills.frameworks.join(", ")}
          </div>
          <div class="col-md-6 mb-2">
            <strong>Cloud:</strong> {skills.cloud.join(", ")}
          </div>
          <div class="col-md-6 mb-2">
            <strong>Containerization:</strong> {skills.containerization.join(", ")}
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
